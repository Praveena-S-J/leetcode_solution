class Solution(object):
    def canFinish(self, numCourses, prerequisites):
        graph = {i: [] for i in range(numCourses)}

        for a, b in prerequisites:
            graph[a].append(b)

        visited = set()
        path = set()

        def dfs(course):
            if course in path:
                return False
            if course in visited:
                return True

            path.add(course)

            for pre in graph[course]:
                if not dfs(pre):
                    return False

            path.remove(course)
            visited.add(course)
            return True

        for c in range(numCourses):
            if not dfs(c):
                return False

        return True
